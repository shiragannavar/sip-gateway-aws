# SIP Gateway configuration
# Copy to .env and fill in values before running docker compose up
# (deploy.sh writes this file automatically — manual editing only needed for direct use)

# Public IP of this host (Elastic IP from Terraform output)
EXTERNAL_IP=

# Internal/private IP of this host (EC2 private IP — RTPEngine binds to this)
# On EC2: TOKEN=$(curl -sX PUT http://169.254.169.254/latest/api/token -H "X-aws-ec2-metadata-token-ttl-seconds:300"); curl -s -H "X-aws-ec2-metadata-token:$TOKEN" http://169.254.169.254/latest/meta-data/local-ipv4
INTERNAL_IP=

# Telephony provider SBC address (IP or FQDN)
CUSTOMER_SBC_ADDRESS=

# Telephony provider SBC SIP port (default: 5060)
CUSTOMER_SBC_PORT=5060

# Inbound calls (from the SBC) forward to ElevenLabs over TCP
ELEVENLABS_SIP_HOST=sip-static.rtc.in.residency.elevenlabs.io
ELEVENLABS_SIP_PORT=5060

# Digest auth credentials (optional — leave empty to disable auth)
AUTH_USER=
AUTH_PASSWORD=
AUTH_REALM=
